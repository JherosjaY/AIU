generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Enrollment {
  id               Int      @id @default(autoincrement())
  firstName        String
  lastName         String
  middleName       String?
  phone            String?
  email            String   @unique
  instEmail        String?  @unique
  course           String?
  document         String?   // General Docs (Birth Cert, etc.)
  reportCard       String?   // Dedicated Academic Record for AI Analysis
  createdAt        DateTime @default(now())
  birthday         String?
  citizenship      String?
  civilStatus      String?
  consent          Boolean?
  emergencyContact String?
  emergencyName    String?
  emergencyRelation String?
  fatherName       String?
  homeBarangay     String?
  homeCity         String?
  homeProvince     String?
  motherName       String?
  birthBarangay    String?
  birthCity        String?
  birthProvince    String?
  gender           String?
  primarySchool    String?
  primaryYear      String?
  secondarySchool  String?
  secondaryYear    String?
  fatherContact    String?
  fatherOccupation String?
  motherContact    String?
  motherOccupation String?
  postalCode       String?
  status           String    @default("PENDING")
  password         String?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  // 📝 INSTITUTIONAL REQUIREMENTS CHECKLIST (For Manual Verification)
  reqBirthCert     Boolean  @default(false)
  reqReportCard    Boolean  @default(false)
  reqGoodMoral     Boolean  @default(false)
  adminNotes       String?
  
  updatedAt        DateTime @updatedAt
  
  // 🧠 AURA AI ANALYTICS (Persistent Decision Support)
  aiStatus         String?   // "QUALIFIED", "AT_RISK", "INCOMPLETE", "READY"
  aiScore          Int?
  aiVerdict        String?   // JUSTIFICATION SUMMARY
  aiSuggestedPivot String?
  lastReminderSent DateTime?
}

model CourseQuota {
  id           Int      @id @default(autoincrement())
  courseAbbr   String   @unique
  courseName   String?
  description  String?
  category     String?  @default("General")
  credits      Int?     @default(120)
  years        Int?     @default(4)
  iconName     String?  @default("GraduationCap")
  color        String?  @default("border-blue-600")
  highlights   String?  @default("Professional Training, Institutional Research, Global Standards")
  maxSlots     Int      @default(50)
  updatedAt    DateTime @updatedAt
}
